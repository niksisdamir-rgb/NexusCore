datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// ─── Concrete Mix Recipes ──────────────────────────────────────────────────
model Recipe {
  id              Int               @id @default(autoincrement())
  name            String
  cementAmount    Float
  waterAmount     Float
  sandAmount      Float
  gravelAmount    Float
  admixtureAmount Float?
  createdAt       DateTime          @default(now())
  ProductionOrder ProductionOrder[]
}

// ─── Production Orders ─────────────────────────────────────────────────────
model ProductionOrder {
  id           Int            @id @default(autoincrement())
  recipeId     Int
  recipe       Recipe         @relation(fields: [recipeId], references: [id])
  quantity     Float
  status       String         @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  operatorId   Int?
  operator     Operator?      @relation(fields: [operatorId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  DeliveryNote DeliveryNote[]
  TelemetryLog TelemetryLog[]
}

model Shift {
  id          Int       @id @default(autoincrement())
  operatorId  Int
  operator    Operator  @relation(fields: [operatorId], references: [id])
  startTime   DateTime  @default(now())
  endTime     DateTime?
  totalVolume Float     @default(0)
  totalOrders Int       @default(0)
  handoffNote String?

  @@index([operatorId])
}

model TelemetryLog {
  id              Int             @id @default(autoincrement())
  orderId         Int
  order           ProductionOrder @relation(fields: [orderId], references: [id])
  mixerLoad       Float
  temperature     Float
  humidity        Float
  vibrationLevel  Float           @default(0)
  timestamp       DateTime        @default(now())

  @@index([orderId])
  @@index([timestamp])
}

// ─── Inventory / Material Stock ────────────────────────────────────────────
model Inventory {
  id           Int      @id @default(autoincrement())
  material     String   @unique
  amount       Float
  capacity     Float
  unit         String   @default("kg")   // kg | L | t | m³
  lowThreshold Float    @default(0)      // alert when amount drops below this
  updatedAt    DateTime @updatedAt
}

// ─── Operators / Users ─────────────────────────────────────────────────────
model Operator {
  id        Int               @id @default(autoincrement())
  name      String
  email     String            @unique
  username  String            @unique
  password  String
  role      String            @default("OPERATOR") // MANAGER | OPERATOR | VIEWER
  shifts    Shift[]
  orders    ProductionOrder[]
  AuditLog  AuditLog[]
}

// ─── Delivery Notes (Otpremnice) ───────────────────────────────────────────
model DeliveryNote {
  id                  Int             @id @default(autoincrement())
  orderId             Int             @unique
  order               ProductionOrder @relation(fields: [orderId], references: [id])
  clientName          String
  siteName            String?
  truckPlate          String?
  driverName          String?
  volumeM3            Float
  deliveredAt         DateTime        @default(now())
  recipeFullName      String?
  orderNumber         String?
  productionNumber    String?
  mixingTime          Int?
  productionStartTime DateTime?
  productionEndTime   DateTime?
  materialStats       String?         // Stored as JSON string
}

// ─── Sensor Readings (SCADA telemetry) ────────────────────────────────────
model SensorReading {
  id          Int      @id @default(autoincrement())
  sensorId    String   // e.g. "cement_silo_1", "mixer_temp"
  sensorType  String   // LEVEL | TEMPERATURE | PRESSURE | FLOW | WEIGHT
  value       Float
  unit        String   // %, °C, bar, L/min, kg
  recordedAt  DateTime @default(now())
}

// ─── Audit Log (traceability) ──────────────────────────────────────────────
model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String   // CREATE | UPDATE | DELETE | STATUS_CHANGE | AI_EXTRACT
  entityType  String   // Recipe | ProductionOrder | Inventory | DeliveryNote
  entityId    Int
  operatorId  Int?
  operator    Operator? @relation(fields: [operatorId], references: [id])
  description String?
  timestamp   DateTime @default(now())
}

// ─── Maintenance & Asset Management ──────────────────────────────────────────
model Asset {
  id              Int               @id @default(autoincrement())
  name            String            @unique // e.g. "Mixer_Motor_A", "Belt_1"
  type            String            // MOTOR | PUMP | CONVEYOR | SILO | STRUCTURE
  installDate     DateTime          @default(now())
  expectedLife    Int               // Expected life in production volume (m3) or hours
  currentUsage    Float             @default(0) // Current volume or hours
  healthScore     Float             @default(100)
  lastService     DateTime?
  status          String            @default("OPERATIONAL") // OPERATIONAL | MAINTENANCE | FAILED
  logs            MaintenanceLog[]
  tickets         MaintenanceTicket[]
}

model MaintenanceLog {
  id          Int      @id @default(autoincrement())
  assetId     Int
  asset       Asset    @relation(fields: [assetId], references: [id])
  action      String   // REPAIR | SERVICE | INSPECTION | CLEANING
  description String
  performedBy String?
  cost        Float?
  timestamp   DateTime @default(now())
}

model MaintenanceTicket {
  id          Int      @id @default(autoincrement())
  assetId     Int
  asset       Asset    @relation(fields: [assetId], references: [id])
  title       String
  description String
  priority    String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Logistics & Fleet Management ───────────────────────────────────────────
model Vehicle {
  id              String   @id // e.g. "T-01"
  plate           String   @unique
  driver          String
  type            String   @default("MIXER") // MIXER | PUMP | SERVICE
  status          String   @default("IDLE")  // IDLE | LOADING | TRANSIT | DELIVERING | RETURNING
  capacity        Float    @default(9.0)     // m3
  currentLoad     Float    @default(0)       // m3
  lastLat         Float    @default(0)
  lastLng         Float    @default(0)
  radarX          Float    @default(0)       // Pixel X for radar UI
  radarY          Float    @default(0)       // Pixel Y for radar UI
  progress        Float    @default(0)       // 0-100%
  destination     String?
  currentOrderId  String?
  lastUpdate      DateTime @default(now())
}

model SiloRefillOrder {
  id          Int      @id @default(autoincrement())
  inventoryId Int
  material    String
  quantity    Float    // kg or L
  unit        String
  status      String   @default("PENDING") // PENDING | ORDERED | IN_TRANSIT | COMPLETED | CANCELLED
  provider    String?  // Supplier name
  eta         DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([inventoryId])
}

