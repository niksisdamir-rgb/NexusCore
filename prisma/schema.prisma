datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Concrete Mix Recipes ──────────────────────────────────────────────────
model Recipe {
  id              Int               @id @default(autoincrement())
  name            String
  cementAmount    Float
  waterAmount     Float
  sandAmount      Float
  gravelAmount    Float
  admixtureAmount Float?
  createdAt       DateTime          @default(now())
  ProductionOrder ProductionOrder[]
}

// ─── Production Orders ─────────────────────────────────────────────────────
model ProductionOrder {
  id           Int            @id @default(autoincrement())
  recipeId     Int
  recipe       Recipe         @relation(fields: [recipeId], references: [id])
  quantity     Float
  status       String         @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  operatorId   Int?
  operator     User?          @relation(fields: [operatorId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  DeliveryNote DeliveryNote[]
  TelemetryLog TelemetryLog[]
}

model User {
  id        Int               @id @default(autoincrement())
  name      String
  role      String            @default("OPERATOR") // OPERATOR, MANAGER
  username  String            @unique
  password  String            // Hashed
  shifts    Shift[]
  orders    ProductionOrder[]
  createdAt DateTime          @default(now())
}

model Shift {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  startTime   DateTime  @default(now())
  endTime     DateTime?
  totalVolume Float     @default(0)
  totalOrders Int       @default(0)

  @@index([userId])
}

model TelemetryLog {
  id              Int             @id @default(autoincrement())
  orderId         Int
  order           ProductionOrder @relation(fields: [orderId], references: [id])
  mixerLoad       Float
  temperature     Float
  humidity        Float
  vibrationLevel  Float           @default(0)
  timestamp       DateTime        @default(now())

  @@index([orderId])
  @@index([timestamp])
}

// ─── Inventory / Material Stock ────────────────────────────────────────────
model Inventory {
  id           Int      @id @default(autoincrement())
  material     String   @unique
  amount       Float
  capacity     Float
  unit         String   @default("kg")   // kg | L | t | m³
  lowThreshold Float    @default(0)      // alert when amount drops below this
  updatedAt    DateTime @updatedAt
}

// ─── Operators / Users ─────────────────────────────────────────────────────
model Operator {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  role      String     // ADMIN | OPERATOR | VIEWER
  AuditLog  AuditLog[]
}

// ─── Delivery Notes (Otpremnice) ───────────────────────────────────────────
model DeliveryNote {
  id          Int             @id @default(autoincrement())
  orderId     Int             @unique
  order       ProductionOrder @relation(fields: [orderId], references: [id])
  clientName  String
  truckPlate  String
  volumeM3    Float
  deliveredAt DateTime        @default(now())
}

// ─── Sensor Readings (SCADA telemetry) ────────────────────────────────────
model SensorReading {
  id          Int      @id @default(autoincrement())
  sensorId    String   // e.g. "cement_silo_1", "mixer_temp"
  sensorType  String   // LEVEL | TEMPERATURE | PRESSURE | FLOW | WEIGHT
  value       Float
  unit        String   // %, °C, bar, L/min, kg
  recordedAt  DateTime @default(now())
}

// ─── Audit Log (traceability) ──────────────────────────────────────────────
model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String   // CREATE | UPDATE | DELETE | STATUS_CHANGE | AI_EXTRACT
  entityType  String   // Recipe | ProductionOrder | Inventory | DeliveryNote
  entityId    Int
  operatorId  Int?
  operator    Operator? @relation(fields: [operatorId], references: [id])
  description String?
  timestamp   DateTime @default(now())
}
